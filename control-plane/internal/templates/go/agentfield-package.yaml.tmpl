config_version: v1
name: {{yamlQuote .NodeID}}
version: 1.0.0
description: {{yamlQuote (printf "Run the %s Go AgentField scaffold locally." .ProjectName)}}
author: {{yamlQuote .AuthorName}}
language: go
entrypoint:
  start: go run .
  healthcheck: /health
agent_node:
  node_id: {{yamlQuote .NodeID}}
  default_port: {{.AgentPort}}
user_environment:
  required: []
